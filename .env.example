# Binance API credentials
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Bitso API credentials (for COP arbitrage)
BITSO_API_KEY=your_bitso_api_key
BITSO_API_SECRET=your_bitso_api_secret

# PostgreSQL (optional — bot runs without it)
DATABASE_URL=postgresql://user:password@localhost:5432/cripton

# Paper trading mode (true = simulate, no real orders)
PAPER_MODE=true

# Log level (trace, debug, info, warn, error)
RUST_LOG=info
